<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — ChordSharp</title>
    <link rel="icon" type="image/png" href="~/images/logo.png" />
    <meta name="description" content="Personal chord sheet manager — store lyrics, place chords, view diagrams." />
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-secondary-container": "#b7b5b4",
                        "on-tertiary-container": "#fffdff",
                        "secondary": "#c8c6c5",
                        "primary-fixed": "#f2daff",
                        "primary-fixed-dim": "#e0b6ff",
                        "on-tertiary-fixed": "#251a00",
                        "on-primary-fixed-variant": "#6a0baa",
                        "on-primary-container": "#fffdff",
                        "error": "#ffb4ab",
                        "inverse-on-surface": "#313030",
                        "surface": "#0D0D14",
                        "surface-container-lowest": "#09090E",
                        "tertiary-fixed": "#ffdf9a",
                        "on-primary-fixed": "#2e004e",
                        "surface-dim": "#0D0D14",
                        "primary": "var(--accent-dynamic, #e0b6ff)",
                        "secondary-fixed": "#e4e2e1",
                        "on-surface": "#e5e2e1",
                        "surface-container-high": "#2a2a2a",
                        "surface-variant": "#353534",
                        "surface-tint": "var(--accent-dynamic, #e0b6ff)",
                        "secondary-container": "#474746",
                        "inverse-primary": "#8433c4",
                        "tertiary-fixed-dim": "#edc156",
                        "surface-container-highest": "#353534",
                        "on-secondary": "#303030",
                        "outline-variant": "#4d4353",
                        "on-secondary-fixed-variant": "#474746",
                        "on-error": "#690005",
                        "surface-container": "#17171F",
                        "on-secondary-fixed": "#1b1c1c",
                        "secondary-fixed-dim": "#c8c6c5",
                        "on-error-container": "#ffdad6",
                        "on-background": "#e5e2e1",
                        "on-surface-variant": "#d0c2d5",
                        "tertiary": "#edc156",
                        "surface-bright": "#3a3939",
                        "primary-container": "var(--accent-dynamic-container, #9d4edd)",
                        "outline": "#998d9e",
                        "background": "#09090E",
                        "on-tertiary": "#3f2e00",
                        "inverse-surface": "#e5e2e1",
                        "tertiary-container": "#947000",
                        "error-container": "#93000a",
                        "on-tertiary-fixed-variant": "#5a4300",
                        "surface-container-low": "#111118",
                        "on-primary": "#4c007d"
                    },
                    borderRadius: {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    spacing: {
                        "gutter": "16px",
                        "md": "16px",
                        "sm": "8px",
                        "margin-desktop": "32px",
                        "margin-mobile": "16px",
                        "lg": "24px",
                        "xs": "4px",
                        "base": "4px",
                        "xl": "40px"
                    },
                    fontFamily: {
                        "body-lg": ["CircularSp", "Circular Std", "Circular", "Figtree", "sans-serif"],
                        "body-md": ["CircularSp", "Circular Std", "Circular", "Figtree", "sans-serif"],
                        "headline-md": ["CircularSp", "Circular Std", "Circular", "Figtree", "sans-serif"],
                        "display-lg": ["CircularSp", "Circular Std", "Circular", "Figtree", "sans-serif"],
                        "headline-sm": ["CircularSp", "Circular Std", "Circular", "Figtree", "sans-serif"],
                        "label-sm": ["CircularSp", "Circular Std", "Circular", "Figtree", "sans-serif"],
                        "label-md": ["CircularSp", "Circular Std", "Circular", "Figtree", "sans-serif"],
                        "display-lg-mobile": ["CircularSp", "Circular Std", "Circular", "Figtree", "sans-serif"],
                        "mono-data": ["JetBrains Mono"]
                    },
                    fontSize: {
                        "body-lg": ["18px", {"lineHeight": "28px", "fontWeight": "400"}],
                        "body-md": ["16px", {"lineHeight": "24px", "fontWeight": "400"}],
                        "headline-md": ["24px", {"lineHeight": "32px", "fontWeight": "600"}],
                        "display-lg": ["48px", {"lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                        "headline-sm": ["20px", {"lineHeight": "28px", "fontWeight": "600"}],
                        "label-sm": ["12px", {"lineHeight": "16px", "letterSpacing": "0.08em", "fontWeight": "600"}],
                        "label-md": ["14px", {"lineHeight": "20px", "letterSpacing": "0.05em", "fontWeight": "500"}],
                        "display-lg-mobile": ["32px", {"lineHeight": "40px", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                        "mono-data": ["14px", {"lineHeight": "20px", "fontWeight": "500"}]
                    }
                }
            }
        };
    </script>
    <style>
        body { 
            background-color: #09090E; 
            color: #e5e2e1; 
        }
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #09090E; }
        ::-webkit-scrollbar-thumb { background: #222228; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #4d4353; }
        .glass-card {
            background: linear-gradient(135deg, rgba(40, 35, 55, 0.4) 0%, rgba(15, 12, 20, 0.7) 100%);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }

        .glass-card, .btn, .chord-card, .form-card, .input-glow-wrapper {
            position: relative;
        }
        .glass-card::after, .btn::after, .chord-card::after, .form-card::after, .input-glow-wrapper::after {
            content: "";
            position: absolute;
            inset: 0;
            border-radius: inherit;
            padding: 1px;
            background: radial-gradient(
                120px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
                var(--accent-dynamic, rgba(224, 182, 255, 1)),
                transparent 100%
            );
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            opacity: 0;
            transition: opacity 0.3s ease;
            pointer-events: none;
            z-index: 10;
        }
        .glass-card:hover::after, .btn:hover::after, .chord-card:hover::after, .form-card:hover::after, .input-glow-wrapper:hover::after, .input-glow-wrapper:focus-within::after {
            opacity: 1;
        }
    </style>
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/vexchords@1.2.0/dist/vexchords.dev.js"></script>
</head>
<body class="font-body-md text-on-surface bg-background">

    @RenderBody()

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener("mousemove", (e) => {
            document.querySelectorAll('.glass-card, .btn, .chord-card, .form-card, .input-glow-wrapper').forEach(el => {
                const rect = el.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                el.style.setProperty('--mouse-x', `${x}px`);
                el.style.setProperty('--mouse-y', `${y}px`);
            });
        });
    </script>
</body>
</html>
