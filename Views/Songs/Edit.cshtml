@model ChordSharp.Models.Song
@{
    ViewData["Title"] = "Edit — " + Model.Title;
}

<div class="page-container">
    <div class="page-header">
    <div>
        <h1 class="page-title">EDIT SONG</h1>
        <p class="page-subtitle">Update details for @Model.Title</p>
    </div>
    <a class="btn btn-secondary btn-sm" asp-action="View" asp-route-id="@Model.Id">← Back to View</a>
</div>

<div class="form-card">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label class="form-label" for="Title">Song Title</label>
            <div class="input-glow-wrapper">
                <input class="form-input" type="text" id="Title" name="Title" value="@Model.Title" required />
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Artist" class="form-label">Artist (Optional)</label>
            <div class="input-glow-wrapper">
                <input asp-for="Artist" class="form-input" />
            </div>
            <span asp-validation-for="Artist" class="text-error text-sm mt-1 block"></span>
        </div>

        <div class="form-group">
            <label asp-for="Album" class="form-label">Album (Optional)</label>
            <div class="input-glow-wrapper">
                <input asp-for="Album" class="form-input" />
            </div>
            <span asp-validation-for="Album" class="text-error text-sm mt-1 block"></span>
        </div>

        <div class="form-group">
            <label class="form-label" for="Lyrics">Lyrics</label>
            <div class="input-glow-wrapper">
                <textarea class="form-textarea mono" id="Lyrics" name="Lyrics" rows="14" required>@Model.Lyrics</textarea>
            </div>
            <p class="form-hint">Use [Section Name] on its own line to mark sections. Editing lyrics will preserve your chord placements, but if line counts change you may need to re-edit chords.</p>
        </div>

        <div class="form-group">
            <label class="form-label" for="StrummingPattern">Strumming Pattern</label>
            <div class="input-glow-wrapper">
                <input class="form-input mono" type="text" id="StrummingPattern" name="StrummingPattern"
                       value="@Model.StrummingPattern"
                       placeholder="e.g. D DU UDU  or  D U D - D U - U" />
            </div>
            <p class="form-hint">Use D (down), U (up), - (muted/skip). Spaces separate beats.</p>
        </div>

        <div class="form-group">
            <label class="form-label" for="Notes">Notes</label>
            <div class="input-glow-wrapper">
                <textarea class="form-textarea" id="Notes" name="Notes" rows="5"
                          placeholder="Any notes about the song — capo position, tuning, tips, etc.">@Model.Notes</textarea>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Audio Tracks (Practice Tracks / Acapellas)</label>
            
            @{
                var tracks = new List<ChordSharp.Models.AudioTrack>();
                if (!string.IsNullOrEmpty(Model.AudioFilesJson))
                {
                    try { tracks = System.Text.Json.JsonSerializer.Deserialize<List<ChordSharp.Models.AudioTrack>>(Model.AudioFilesJson) ?? new List<ChordSharp.Models.AudioTrack>(); }
                    catch { }
                }
            }
            
            @if (tracks.Any())
            {
                <div style="margin-bottom:1.5rem;display:flex;flex-direction:column;gap:12px;">
                    @foreach (var track in tracks)
                    {
                        <div style="background:var(--bg-input);border:1px solid var(--border-subtle);border-radius:var(--radius-md);padding:12px;">
                            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
                                <div style="display:flex;align-items:center;gap:8px;">
                                    <span style="font-size:16px;">🎧</span>
                                    <span style="font-size:13px;font-weight:600;color:var(--text-primary);">@track.Label</span>
                                </div>
                                <button type="button" class="btn btn-danger btn-sm" onclick="document.getElementById('remove-track-@track.Id').submit();">Remove</button>
                            </div>
                            <audio controls style="width:100%;height:36px;border-radius:4px;">
                                <source src="/uploads/audio/@track.FileName" />
                            </audio>
                        </div>
                    }
                </div>
            }

            <div style="background:var(--bg-card);border:1px dashed var(--border-medium);border-radius:var(--radius-md);padding:16px;">
                <p style="font-size:13px;color:var(--text-secondary);margin-bottom:12px;font-weight:600;">Add New Track</p>
                <div style="display:flex;flex-wrap:wrap;gap:12px;margin-bottom:10px;">
                    <div class="input-glow-wrapper" style="flex:1;min-width:200px;">
                        <input class="form-input" type="text" name="audioLabel" placeholder="Label (e.g. Acapella, Backing Track)" />
                    </div>
                    <input class="form-input" type="file" name="audioFile" accept=".mp3,.wav,.ogg,.m4a,.flac,.aac,.webm" style="flex:2;min-width:200px;padding:10px;" />
                </div>
                <p class="form-hint" style="margin:0;">Upload MP3, WAV, OGG, M4A, FLAC, AAC, or WebM.</p>
            </div>
        </div>

        <div style="display:flex;gap:10px;justify-content:flex-end;">
            <a class="btn btn-ghost" asp-action="View" asp-route-id="@Model.Id">Cancel</a>
            <button class="btn btn-primary" type="submit">Save Changes</button>
        </div>
    </form>
</div>

<div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border-subtle);">
    <h2 style="font-family:var(--font-display);font-size:18px;letter-spacing:1px;color:var(--accent-red);margin-bottom:8px;">DANGER ZONE</h2>
    
    @if (!string.IsNullOrEmpty(Model.AudioFilesJson))
    {
        var tracks = new List<ChordSharp.Models.AudioTrack>();
        try { tracks = System.Text.Json.JsonSerializer.Deserialize<List<ChordSharp.Models.AudioTrack>>(Model.AudioFilesJson) ?? new List<ChordSharp.Models.AudioTrack>(); } catch { }
        
        foreach (var track in tracks)
        {
            <form id="remove-track-@track.Id" asp-action="RemoveAudio" asp-route-id="@Model.Id" method="post" style="display:none;" onsubmit="return confirm('Remove track \'@track.Label\'?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="trackId" value="@track.Id" />
            </form>
        }
    }

    <p style="font-size:13px;color:var(--text-tertiary);margin-bottom:12px;">Permanently delete this song and all its chord data.</p>
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
          onsubmit="return confirm('Are you sure you want to delete this song? This cannot be undone.');">
        @Html.AntiForgeryToken()
        <button class="btn btn-danger btn-sm" type="submit">🗑 Delete Song</button>
    </form>
</div>
</div>
